{"type":"item.started","item":{"id":"item_25","type":"command_execution","command":"/usr/bin/bash -lc \"pwd && source .venv/bin/activate && python - << 'PY'\nfrom pathlib import Path\nfrom pypdf import PdfReader\nimport re, json\npages=Path('papers/pages')\n# collect first chunk text for each paper\nfirst_chunks=sorted([p for p in pages.glob('*_chunk_001.pdf')])\nnotes={}\nfor c in first_chunks:\n    text='\\\\n'.join((page.extract_text() or '') for page in PdfReader(str(c)).pages)\n    key=c.name.replace('_chunk_001.pdf','')\n    # compact snippet for abstract-ish part\n    t=' '.join(text.split())\n    notes[key]={'chunk1_snippet':t[:900]}\n\n# deep read all chunks for selected papers\nfor key in ['1706.03762_attention_is_all_you_need','1706.06978_deep_interest_network_ctr','1808.09781_sasrec']:\n    chunks=sorted(pages.glob(f'{key}_chunk_*.pdf'))\n    full=[]\n    for ch in chunks:\n        txt='\\\\n'.join((page.extract_text() or '') for page in PdfReader(str(ch)).pages)\n        full.append(' '.join(txt.split()))\n    alltxt=' '.join(full)\n    notes[key]['deep_total_chars']=len(alltxt)\n    # simple heuristic extractions\n    for label,pat in [\n        ('datasets',r'(?:dataset|datasets|MovieLens|Amazon|WMT|IWSLT)[\"'^'\"\\\\.]{0,220}\\\\.'),\n        ('metrics',r'(?:AUC|NDCG|HR@\\\\d+|BLEU|FID|accuracy|perplexity)[\"'^'\"\\\\.]{0,220}\\\\.'),\n        ('baselines',r'(?:baseline|baselines|compared with|compare against)[\"'^'\"\\\\.]{0,220}\\\\.'),\n        ('results',r'(?:results show|outperform|improvement|state-of-the-art|SOTA)[\"'^'\"\\\\.]{0,220}\\\\.')\n    ]:\n        m=re.findall(pat,alltxt,flags=re.I)\n        notes[key][label]=m[:6]\n\nPath('paper_notes_raw.json').write_text(json.dumps(notes,indent=2))\nprint('wrote paper_notes_raw.json with',len(notes),'entries')\nfor k in sorted(notes)[:5]:\n    print(k,':',notes[k]['chunk1_snippet'][:140])\nPY\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
